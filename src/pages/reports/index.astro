---
import Layout from '../../layouts/Layout.astro';
import ReportCard from '../../components/reports/ReportCard.astro';
import { Icon } from 'astro-icon/components';
import { getCollection, getEntry } from 'astro:content';
const allReports = await getCollection('reports');


// Load linked projects and precompute data for each report
const reportCards = await Promise.all(allReports.map(async (report) => {
  const { project_id } = report.data;
  const project = project_id ? await getEntry('projects', project_id) : null;
  const client = project?.data.client;
  const date = project?.data.date ?? report.data.date;
  const co2PerView = report.data.use_metrics?.co2_per_view_g;

  return { report, co2PerView, client, date };
}));

// Sort by date, newest first
reportCards.sort((a, b) => (b.date?.getTime() ?? 0) - (a.date?.getTime() ?? 0));
---

<Layout
  title="Eco Reports — Nicolas Chesné"
  description="Per-project eco footprint reports: embodied CO₂ from hardware and services, use energy metrics."
>
  <header class="reports-hero inverted">
    <div class="hero-inner">
      <h1>
        <span>Eco</span>
        <span>Reports</span>
        <span class="sprout"><Icon name="lucide:sprout" /></span>
      </h1>
      <p>
        Each project report details its embodied CO₂ (hardware &amp; services amortised over build time)
        and use energy (page weight, CO₂ per view, performance).
      </p>
    </div>
  </header>

  <section class="reports-section">
    {reportCards.length === 0 ? (
      <p class="empty">No reports yet.</p>
    ) : (
      <ul class="reports-grid">
        {reportCards.map(({ report, co2PerView, client, date }) => (
          <ReportCard
            report={report}
            co2PerView={co2PerView}
            client={client}
            date={date}
          />
        ))}
      </ul>
    )}
  </section>
</Layout>

<style lang="scss">
.reports-hero {
  @include set-color(true);
  border-bottom: $border;
  margin: calc(-1 * var(--layoutMargin)) calc(-1 * var(--layoutMargin)) 0;

  .hero-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 4rem var(--layoutMargin) 3rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  h1 {
    display: flex;
    flex-direction: column;
    gap: 0;
    font-size: 5rem;
    line-height: 0.9;

    @include desktop() {
      font-size: 9rem;
    }

    span:nth-child(2) {
      align-self: flex-end;
    }

    .sprout {
      align-self: flex-start;
      font-size: 3rem;
      color: $yellow;
      animation: 1.8s grow infinite;

      @keyframes grow {
        0%, 100% { transform: scale(1); }
        50% { transform: scale(1.2); }
      }
    }
  }

  p {
    max-width: 600px;
    opacity: 0.7;
    font-size: 1.1rem;
  }
}

.reports-section {
  margin: 4rem auto;
  max-width: 1400px;
}

.reports-grid {
  list-style: none;
  margin: 0;
  padding: 0;
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  gap: 1.5rem;
}

.empty {
  opacity: 0.5;
  font-size: 1.1rem;
}
</style>
