---
import CommonHeader from '../components/common/ui/Header.astro';
import AppSticky from '../components/common/ui/AppSticky.astro';
import CommonFooter from '../components/common/ui/Footer.astro';
import { ClientRouter } from 'astro:transitions';
import '../scss/reset.scss';
import '../scss/variables.scss';
import '../scss/main.scss';

import '@fontsource/space-grotesk';

interface Props {
  accent?: string;
  title?: string;
  description?: string;
}
const { accent, title, description } = Astro.props;
const umamiHost = import.meta.env.PUBLIC_UMAMI_HOST;
const umamiWebsiteId = import.meta.env.PUBLIC_UMAMI_WEBSITE_ID;
---
<!doctype html>
<html lang="en" style={accent ? `--mainColor: ${accent}` : ''}>
	<head>
		<meta charset="UTF-8" />
		<title>{title ?? 'Nicolas Chesné - Fullstack Freelance Developer'}</title>
		<meta name="viewport" content="width=device-width" />
		<ClientRouter />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		{umamiHost && umamiWebsiteId && (
			<script
				is:inline
				defer
				src={`${umamiHost}/script.js`}
				data-website-id={umamiWebsiteId}
				data-do-not-track="true"
				data-performance="true"
			/>
		)}
		<meta name="description" content={description ?? 'Nicolas Chesné - Full stack Freelance Developer - Based in Paris - 20 years of experience'} />
		<meta name="keywords" content="freelance, developer, fullstack, web, javascript, strapi, vue, nodejs, paris, sustainable web design" />
		<meta name="author" content="Nicolas Chesné" />
		<meta name="robots" content="index, follow" />
		<meta name="googlebot" content="index, follow" />
		<meta name="theme-color" content="#000000" />
		<meta property="og:title" content="Nicolas Chesné - Fullstack Freelance Developer" />
		<meta property="og:description" content="Nicolas Chesné - Full stack Freelance Developer - Based in Paris - 20 years of experience" />
		<meta property="og:image" content="/og-image.png" />
		<meta property="og:url" content="https://nicolaschesne.fr" />
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="Nicolas Chesné" />
		<meta property="og:locale" content="en_US" />

		<!-- <meta http-equiv="Content-Security-Policy" content="default-src 'self'; img-src 'self' data:; script-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self' https://fonts.gstatic.com; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none';" />
		<meta http-equiv="X-Content-Type-Options" content="nosniff" />
		<meta http-equiv="X-Frame-Options" content="DENY" />
		<meta http-equiv="Referrer-Policy" content="strict-origin-when-cross-origin" />
		<meta http-equiv="Permissions-Policy" content="" /> -->
		
		<!-- Twitter Card data -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content="Nicolas Chesné - Fullstack Freelance Developer" />
		<meta name="twitter:description" content="Nicolas Chesné - Full stack Freelance Developer - Based in Paris - 20 years of experience" />
		<meta name="twitter:image" content="/og-image.png" />
	</head>
	<body>
		<CommonHeader />
		<main>
			<slot />
		</main>
		<AppSticky />
		<CommonFooter class="app__footer" />
	</body>
</html>

<style>

	html,
	body {
		margin: 0;
		width: 100%;
		position: relative;
	}

	main {
  	padding: 2rem 2rem 0;
	}
</style>

<!--
	Page transition: a solid black curtain that sweeps right -> left.
	Phase 1 (0 -> 50%): the old page is clipped away from the right edge,
	revealing the black backdrop underneath -> the screen becomes fully black.
	Phase 2 (50 -> 100%): the new page is drawn in from the right over the black.
	Hard clip edges only, no opacity fades — matches the "everything at the cut"
	design system. Reduced-motion users get an instant cut (no sweep).
-->
<style is:global>
	::view-transition {
		background-color: #000;
	}

	/* Avoid the browser's default cross-fade; we drive the motion ourselves. */
	::view-transition-old(root),
	::view-transition-new(root) {
		mix-blend-mode: normal;
	}

	::view-transition-old(root) {
		z-index: 2;
		animation: curtain-cover 0.55s cubic-bezier(0.76, 0, 0.24, 1) both;
	}

	::view-transition-new(root) {
		z-index: 1;
		animation: curtain-reveal 0.55s cubic-bezier(0.76, 0, 0.24, 1) both;
	}

	@keyframes curtain-cover {
		0%   { clip-path: inset(0 0 0 0); }
		50%  { clip-path: inset(0 100% 0 0); }
		100% { clip-path: inset(0 100% 0 0); }
	}

	@keyframes curtain-reveal {
		0%   { clip-path: inset(0 0 0 100%); }
		50%  { clip-path: inset(0 0 0 100%); }
		100% { clip-path: inset(0 0 0 0); }
	}

	@media (prefers-reduced-motion: reduce) {
		::view-transition-old(root),
		::view-transition-new(root) {
			animation: none;
		}
	}
</style>
