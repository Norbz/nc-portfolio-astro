---
import { Icon } from "astro-icon/components";
import {
    computeDailyCO2,
    computeHardwareCO2ForProject,
    computeDeviceEnergyForProject,
    computeEffectiveLifespanDays,
    isUsingActualLifespan,
    round,
} from "../../utils/co2";

const { hardware, durationDays, referenceDate } = Astro.props;

const ref: Date = referenceDate ?? new Date();
const dailyCO2 = round(computeDailyCO2(hardware, ref), 4);
const effectiveDays = computeEffectiveLifespanDays(hardware, ref);
const lifespanLabel = isUsingActualLifespan(hardware, ref) ? "Effective lifespan" : "Estimated lifespan";

const embodiedCO2 = hardware.lifecycle_co2 * (1 - hardware.use_phase_percent);
const useCO2PerDayMfr = (hardware.lifecycle_co2 * hardware.use_phase_percent) / hardware.manufacturer_lifespan_days;
const actualLifecycleCO2 = round(embodiedCO2 + useCO2PerDayMfr * effectiveDays, 1);
const projectCO2 = durationDays
    ? round(computeHardwareCO2ForProject(hardware, durationDays, ref), 3)
    : null;
const projectKwh = durationDays && hardware.wattage && hardware.daily_hours
    ? round(computeDeviceEnergyForProject(hardware, durationDays), 2)
    : null;
---

<article class="hardware-card">
    <Icon name={hardware.icon} class="icon" />
    <div class="info">
        <h3>{hardware.name}</h3>
        <p class="description">{hardware.description}</p>
        <ul class="stats">
            <li data-tooltip="Manufacturing CO₂ spread over the device's effective lifespan. Longer retention lowers this figure.">
                <span class="label">Daily CO₂</span>
                <span class="value">{dailyCO2} kg/day</span>
            </li>
            {hardware.ratio !== undefined && hardware.ratio !== 1 && (
                <li data-tooltip="Fraction of the workday this device is used for professional work.">
                    <span class="label">Usage ratio</span>
                    <span class="value">{hardware.ratio * 100}% of workday</span>
                </li>
            )}
            <li data-tooltip={lifespanLabel === "Effective lifespan"
                ? "Device has outlived its estimated lifespan — daily CO₂ is now lower than the manufacturer's baseline."
                : "Target working-day lifespan (200 days/year model). Daily CO₂ decreases once the device outlives this."}>
                <span class="label">{lifespanLabel}</span>
                <span class="value">{effectiveDays} days</span>
            </li>
            <li class="details-row">
                <details class="methodology">
                    <summary>Details</summary>
                    <ul class="methodology-stats">
                        {hardware.wattage && (
                            <li data-tooltip="Average power draw under typical workload.">
                                <span class="label">Wattage</span>
                                <span class="value">{hardware.wattage} W</span>
                            </li>
                        )}
                        <li data-tooltip="Share of total lifecycle CO₂ attributed to energy consumption during use, vs. manufacturing.">
                            <span class="label">Use phase</span>
                            <span class="value">{Math.round(hardware.use_phase_percent * 100)}%</span>
                        </li>
                        <li data-tooltip="Total CO₂ as reported in the manufacturer's environmental report, for their stated lifespan.">
                            <span class="label">Manufacturer lifecycle CO₂</span>
                            <span class="value">{hardware.lifecycle_co2} kg</span>
                        </li>
                        <li data-tooltip="Recalculated lifecycle CO₂ based on actual usage duration. Higher than the manufacturer figure when the device is kept past its estimated lifespan.">
                            <span class="label">Actual lifecycle CO₂</span>
                            <span class="value">{actualLifecycleCO2} kg</span>
                        </li>
                        {hardware.water_per_day_l && (
                            <li data-tooltip="Virtual water embedded in manufacturing, amortised over daily use.">
                                <span class="label">Daily water</span>
                                <span class="value">{hardware.water_per_day_l} L/day</span>
                            </li>
                        )}
                    </ul>
                    {hardware.methodology && (
                        <p class="methodology-detail">{hardware.methodology}</p>
                    )}
                </details>
            </li>
            {projectCO2 !== null && (
                <li class="project-contribution" data-tooltip="CO₂ attributed to this device for the project duration, scaled by usage ratio.">
                    <span class="label">This project</span>
                    <span class="project-values">
                        <span class="value highlight">{projectCO2} kg CO₂</span>
                        {projectKwh !== null && (
                            <span class="value kwh">{projectKwh} kWh</span>
                        )}
                    </span>
                </li>
            )}
        </ul>

        {hardware.comments && <p class="comments">{hardware.comments}</p>}
        {hardware.source && (
            <a href={hardware.source} target="_blank" rel="noopener noreferrer" class="source">
                Source <Icon name="lucide:external-link" size="12" />
            </a>
        )}
    </div>
</article>

<style lang="scss">
    .hardware-card {
        display: flex;
        gap: 1.5rem;
        background: var(--mainColor);
        border: $border;
        box-shadow: $shadow;
        padding: 1.5rem;
        align-items: flex-start;

        .icon {
            width: 48px;
            height: 48px;
            flex-shrink: 0;
        }

        .info {
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 0.5rem;

            h3 {
                font-size: 1.1rem;
                margin: 0;
            }

            .description {
                font-size: 0.9rem;
                opacity: 0.7;
            }

            .stats {
                list-style: none;
                margin: 0.5rem 0 0;
                padding: 0;
                display: flex;
                flex-direction: column;
                gap: 0.2rem;

                li {
                    display: flex;
                    justify-content: space-between;
                    font-size: 0.9rem;
                    gap: 1rem;
                    position: relative;

                    &[data-tooltip]:hover::before {
                        content: attr(data-tooltip);
                        position: absolute;
                        bottom: calc(100% + 6px);
                        left: 0;
                        width: max-content;
                        max-width: 280px;
                        background: var(--textColor);
                        color: var(--mainColor);
                        font-size: 0.75rem;
                        line-height: 1.4;
                        padding: 0.4rem 0.6rem;
                        border: 1px solid var(--mainColor);
                        pointer-events: none;
                        z-index: 10;
                        white-space: normal;
                    }

                    .label {
                        opacity: 0.6;
                    }

                    .value {
                        font-variant-numeric: tabular-nums;
                        font-weight: 400;
                    }

                    &.project-contribution {
                        margin-top: 0.4rem;
                        padding-top: 0.4rem;
                        border-top: 1px solid var(--textColor);
                        align-items: flex-start;

                        .project-values {
                            display: flex;
                            flex-direction: column;
                            align-items: flex-end;
                            gap: 0.2rem;
                        }

                        .highlight {
                            @include set-color(true);
                            padding: 0.1rem 0.4rem;
                        }

                        .kwh {
                            font-size: 0.8rem;
                            opacity: 0.6;
                        }
                    }
                }
            }

            .comments {
                font-size: 0.8rem;
                opacity: 0.6;
                margin: 0.5rem 0 0;
            }

            .source {
                font-size: 0.8rem;
                color: var(--textColor);
                display: inline-flex;
                align-items: center;
                gap: 0.2rem;
                margin-top: 0.25rem;
                opacity: 0.6;
            }

            .details-row {
                display: block;
            }

            .methodology {
                margin-top: 0;
                width: 100%;

                summary {
                    font-size: 0.8rem;
                    opacity: 0.5;
                    cursor: pointer;
                    list-style: none;
                    display: inline-flex;
                    align-items: center;
                    gap: 0.3rem;
                    user-select: none;

                    &::-webkit-details-marker { display: none; }

                    &::after {
                        content: "↓";
                        font-size: 0.7rem;
                        transition: transform 0.15s ease;
                    }
                }

                &[open] summary::after {
                    transform: rotate(180deg);
                }

                .methodology-stats {
                    list-style: none;
                    margin: 0.5rem 0 0;
                    padding: 0;
                    display: flex;
                    flex-direction: column;
                    gap: 0.2rem;

                    li {
                        display: flex;
                        justify-content: space-between;
                        font-size: 0.85rem;
                        gap: 1rem;
                        width: 100%;
                        position: relative;

                        &[data-tooltip]:hover::before {
                            content: attr(data-tooltip);
                            position: absolute;
                            bottom: calc(100% + 6px);
                            left: 0;
                            width: max-content;
                            max-width: 280px;
                            background: var(--textColor);
                            color: var(--mainColor);
                            font-size: 0.75rem;
                            line-height: 1.4;
                            padding: 0.4rem 0.6rem;
                            border: 1px solid var(--mainColor);
                            pointer-events: none;
                            z-index: 10;
                            white-space: normal;
                        }

                        .label { opacity: 0.6; }
                        .value {
                            font-variant-numeric: tabular-nums;
                            text-align: right;
                        }
                    }
                }

                .methodology-detail {
                    font-size: 0.78rem;
                    opacity: 0.55;
                    font-style: italic;
                    margin: 0.5rem 0 0;
                }
            }
        }
    }
</style>
