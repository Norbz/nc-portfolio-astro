---
import { Icon } from "astro-icon/components";
import {
    computeDailyCO2,
    computeHardwareCO2ForProject,
    computeDeviceEnergyForProject,
    computeEffectiveLifespanDays,
    isUsingActualLifespan,
    round,
} from "../../utils/co2";

const { hardware, durationDays, referenceDate } = Astro.props;

const ref: Date = referenceDate ?? new Date();
const dailyCO2 = round(computeDailyCO2(hardware, ref), 4);
const effectiveDays = computeEffectiveLifespanDays(hardware, ref);
const lifespanLabel = isUsingActualLifespan(hardware, ref) ? "Effective lifespan" : "Estimated lifespan";
const projectCO2 = durationDays
    ? round(computeHardwareCO2ForProject(hardware, durationDays, ref), 3)
    : null;
const projectKwh = durationDays && hardware.wattage && hardware.daily_hours
    ? round(computeDeviceEnergyForProject(hardware, durationDays), 2)
    : null;
---

<article class="hardware-card">
    <Icon name={hardware.icon} class="icon" />
    <div class="info">
        <h3>{hardware.name}</h3>
        <p class="description">{hardware.description}</p>
        <ul class="stats">
            <li>
                <span class="label">Daily CO₂</span>
                <span class="value">{dailyCO2} kg/day</span>
            </li>
            {hardware.ratio !== undefined && hardware.ratio !== 1 && (
                <li>
                    <span class="label">Usage ratio</span>
                    <span class="value">{hardware.ratio * 100}% of workday</span>
                </li>
            )}
            <li>
                <span class="label">{lifespanLabel}</span>
                <span class="value">{effectiveDays} days</span>
            </li>
            {projectCO2 !== null && (
                <li class="project-contribution">
                    <span class="label">This project</span>
                    <span class="project-values">
                        <span class="value highlight">{projectCO2} kg CO₂</span>
                        {projectKwh !== null && (
                            <span class="value kwh">{projectKwh} kWh</span>
                        )}
                    </span>
                </li>
            )}
        </ul>

        <details class="methodology">
            <summary>Details</summary>
            <ul class="methodology-stats">
                {hardware.wattage && (
                    <li>
                        <span class="label">Wattage</span>
                        <span class="value">{hardware.wattage} W</span>
                    </li>
                )}
                <li>
                    <span class="label">Use phase</span>
                    <span class="value">{Math.round(hardware.use_phase_percent * 100)}%</span>
                </li>
                <li>
                    <span class="label">Lifecycle CO₂</span>
                    <span class="value">{hardware.lifecycle_co2} kg</span>
                </li>
                {hardware.water_per_day_l && (
                    <li>
                        <span class="label">Daily water</span>
                        <span class="value">{hardware.water_per_day_l} L/day</span>
                    </li>
                )}
            </ul>
            {(hardware.comments || hardware.source) && (
                <div class="methodology-note">
                    {hardware.comments && <p>{hardware.comments}</p>}
                    {hardware.source && (
                        <a href={hardware.source} target="_blank" rel="noopener noreferrer" class="source">
                            Source <Icon name="lucide:external-link" size="11" />
                        </a>
                    )}
                </div>
            )}
        </details>
    </div>
</article>

<style lang="scss">
    .hardware-card {
        display: flex;
        gap: 1.5rem;
        background: var(--mainColor);
        border: $border;
        box-shadow: $shadow;
        padding: 1.5rem;
        align-items: flex-start;

        .icon {
            width: 48px;
            height: 48px;
            flex-shrink: 0;
        }

        .info {
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 0.5rem;

            h3 {
                font-size: 1.1rem;
                margin: 0;
            }

            .description {
                font-size: 0.9rem;
                opacity: 0.7;
            }

            .stats {
                list-style: none;
                margin: 0.5rem 0 0;
                padding: 0;
                display: flex;
                flex-direction: column;
                gap: 0.2rem;

                li {
                    display: flex;
                    justify-content: space-between;
                    font-size: 0.9rem;
                    gap: 1rem;

                    .label {
                        opacity: 0.6;
                    }

                    .value {
                        font-variant-numeric: tabular-nums;
                        font-weight: 400;
                    }

                    &.project-contribution {
                        margin-top: 0.4rem;
                        padding-top: 0.4rem;
                        border-top: 1px solid var(--textColor);
                        align-items: flex-start;

                        .project-values {
                            display: flex;
                            flex-direction: column;
                            align-items: flex-end;
                            gap: 0.2rem;
                        }

                        .highlight {
                            @include set-color(true);
                            padding: 0.1rem 0.4rem;
                        }

                        .kwh {
                            font-size: 0.8rem;
                            opacity: 0.6;
                        }
                    }
                }
            }

            .methodology {
                margin-top: 0.75rem;
                border-top: 1px solid var(--textColor);
                padding-top: 0.5rem;

                summary {
                    font-size: 0.8rem;
                    opacity: 0.5;
                    cursor: pointer;
                    list-style: none;
                    display: inline-flex;
                    align-items: center;
                    gap: 0.3rem;
                    user-select: none;

                    &::-webkit-details-marker { display: none; }

                    &::after {
                        content: "↓";
                        font-size: 0.7rem;
                        transition: transform 0.15s ease;
                    }
                }

                &[open] summary::after {
                    transform: rotate(180deg);
                }

                .methodology-stats {
                    list-style: none;
                    margin: 0.5rem 0 0;
                    padding: 0;
                    display: flex;
                    flex-direction: column;
                    gap: 0.2rem;

                    li {
                        display: flex;
                        justify-content: space-between;
                        font-size: 0.85rem;
                        gap: 1rem;

                        .label { opacity: 0.6; }
                        .value { font-variant-numeric: tabular-nums; }
                    }
                }

                .methodology-note {
                    margin-top: 0.5rem;
                    display: flex;
                    flex-direction: column;
                    gap: 0.3rem;

                    p {
                        font-size: 0.78rem;
                        opacity: 0.55;
                        margin: 0;
                        font-style: italic;
                    }

                    .source {
                        font-size: 0.75rem;
                        color: var(--textColor);
                        display: inline-flex;
                        align-items: center;
                        gap: 0.2rem;
                        opacity: 0.6;
                    }
                }
            }
        }
    }
</style>
