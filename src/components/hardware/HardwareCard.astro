---
import { Icon } from 'astro-icon/components'
const { hardware, duration } = Astro.props;
---
<article class="hardware-card">
  <Icon name={hardware.icon} class="icon" />
  <div class="info">
    <h3>{hardware.name}</h3>
    <p>{hardware.description}</p>
    <p><strong>Duration:</strong> {duration} years</p>
    <p><strong>CO₂ lifecycle:</strong> {hardware.lifecycle_co2} kg</p>
    <p><strong>Lifespan:</strong> {hardware.lifecycle_lifespan} years</p>
    {hardware.wattage && <p><strong>Wattage:</strong> {hardware.wattage} W</p>}
    {hardware.source && <p><a href={hardware.source} target="_blank">Source</a></p>}
    {hardware.comments && <p class="comments">{hardware.comments}</p>}
  </div>
</article>
<style lang="scss">
.hardware-card {
  display: flex;
  gap: 1.5rem;
  background: $yellow;
  border: $border;
  padding: 1.5rem;
  margin-bottom: 1.5rem;
  align-items: flex-start;
  .icon {
    width: 64px;
    height: 64px;
    img {
      width: 100%;
      height: 100%;
      object-fit: contain;
    }
  }
  .info {
    flex: 1;
    h3 {
      margin: 0 0 0.5rem 0;
      font-size: 1.2rem;
    }
    p {
      margin: 0.2rem 0;
      font-size: 1rem;
    }
    .comments {
      font-style: italic;
      color: $black;
      opacity: 0.7;
    }
  }
}
</style>
