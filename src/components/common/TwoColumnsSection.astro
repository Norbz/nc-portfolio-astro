---
import { Icon } from 'astro-icon/components'
const { titleLevel, ...rest } = Astro.props;
const HeadingElement = `${"h"+(titleLevel || 2)}`;
---
<section>
  <HeadingElement><slot name="title" {...rest} class="title"></slot></HeadingElement>
  <div>
    <slot />
  </div>
</section>
<style lang="scss">
section {
  $sectionGap: 4rem;
  
  position: relative;
  margin: 8rem auto;
  max-width: 1920px;
  padding: 0;
  display: grid;
  grid-template-columns: 1fr;
  grid-gap: 4rem;

  @include above(calc(600px + ($sectionGap + ($layoutMargin * 2)))) {
    grid-template-columns: 220px 1fr;
  }

  @include above(990px) {
    grid-template-columns: 1fr 1fr;
  }

  >:last-child {
    min-width: 0;
  }
  h2, h3, h4 {
    @include above(calc(600px + ($sectionGap + ($layoutMargin * 2)))) {
      font-size: 1.6rem;
      height: fit-content;
      position: sticky;
      top: 60px;
      padding-top: 1rem;
    }

    @include above(990px) {
      font-size: 2.5rem;
    }
  }
}
</style>