---
import { Icon } from "astro-icon/components";

interface Props {
    label: string;
    value: string | number;
    unit?: string;
    icon?: string;
    accent?: boolean;
    tooltip?: string;
}
const { label, value, unit, icon, accent = false, tooltip } = Astro.props;
---

<div class:list={["metric-card", { accent }]} data-tooltip={tooltip}>
    {icon && <Icon name={icon} class="metric-icon" size="20" />}
    <div class="metric-value">
        <span class="value">{value}</span>
        {unit && <span class="unit">{unit}</span>}
    </div>
    <p class="metric-label">{label}</p>
</div>

<style lang="scss">
    .metric-card {
        border: $border;
        box-shadow: $shadow;
        padding: 1.25rem 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
        background: var(--mainColor);
        position: relative;

        @media (hover: hover) {
            &[data-tooltip]:hover::before {
                content: attr(data-tooltip);
                position: absolute;
                bottom: calc(100% + 6px);
                left: 0;
                width: max-content;
                max-width: 300px;
                background: var(--textColor);
                color: var(--mainColor);
                font-size: 0.75rem;
                line-height: 1.4;
                padding: 0.4rem 0.6rem;
                border: 1px solid var(--mainColor);
                pointer-events: none;
                z-index: 10;
                white-space: normal;
            }
        }

        &.accent {
            @include set-color(true);
        }

        .metric-icon {
        }

        .metric-value {
            display: flex;
            align-items: baseline;
            gap: 0.3rem;

            .value {
                font-size: 2rem;
                line-height: 1;
                font-variant-numeric: tabular-nums;
            }

            .unit {
                font-size: 0.85rem;
                opacity: 0.6;
            }
        }

        .metric-label {
            font-size: 0.85rem;
            opacity: 0.6;
            margin: 0;
        }
    }
</style>
