---
import { Icon } from "astro-icon/components";

interface Props {
    report: any;
    co2PerView?: number;
    client?: string;
    date?: Date;
}
const { report, co2PerView, client, date } = Astro.props;
const { title, description, accent, tags, project_id } = report.data;

const formattedDate = date?.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
});
---

<li class="report-card">
    <a href={`/reports/${report.id}`} class="card-inner">
        <div class="card-top">
            <div class="card-meta">
                {client && <span class="client">{client}</span>}
                {date && <time datetime={date.toISOString()}>{formattedDate}</time>}
            </div>
            <h2>{title}</h2>
            <p class="card-description">{description}</p>
        </div>

        <div class="card-bottom">
            <div class="tags">
                {
                    tags &&
                        tags
                            .slice(0, 3)
                            .map((tag: string) => (
                                <span class="tag">{tag}</span>
                            ))
                }
            </div>
            {
                co2PerView !== undefined && (
                    <span class="co2-badge">
                        <Icon name="lucide:wind" size="14" />
                        {co2PerView} g CO₂/view
                    </span>
                )
            }
        </div>
    </a>
</li>

<style lang="scss">
    .report-card {
        list-style: none;
        border: $border;
        box-shadow: $shadow;
        transition: box-shadow 0.15s ease;

        &:hover {
            box-shadow: none;
        }

        .card-inner {
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            padding: 1.5rem;
            gap: 1.5rem;
            height: 100%;
            box-sizing: border-box;
            color: var(--textColor);
            background: var(--mainColor);
            text-decoration: none;
        }

        .card-top {
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
        }

        .card-meta {
            display: flex;
            gap: 0.75rem;
            font-size: 0.85rem;
            opacity: 0.6;

            .client::after {
                content: "—";
                margin-left: 0.75rem;
            }
        }

        h2 {
            font-size: 1.4rem;
            margin: 0;
        }

        .card-description {
            font-size: 0.95rem;
            opacity: 0.7;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .card-bottom {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            gap: 1rem;
            flex-wrap: wrap;
        }

        .tags {
            display: flex;
            flex-wrap: wrap;
            gap: 0.4rem;

            .tag {
                font-size: 0.75rem;
                border: $border;
                padding: 0.15rem 0.5rem;
            }
        }

        .co2-badge {
            display: inline-flex;
            align-items: center;
            gap: 0.3rem;
            font-size: 0.85rem;
            @include set-color(true);
            padding: 0.2rem 0.6rem;
            border: $border;
            white-space: nowrap;
        }
    }
</style>
