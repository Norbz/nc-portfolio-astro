---
import { Icon } from 'astro-icon/components'
---
<div>
  <h1><slot /></h1>
</div>

<style lang="scss">
div {
  margin: 3rem auto 5rem;
  max-width: 1400px;
  p {
    margin: 0.6rem 0;

    &.hello {
      padding: 0.5rem 1rem;
      font-size: 1.5rem;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      width: fit-content;
    }
  }
  h1 {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;


    & > span {
      text-align: center;
    }

    & > span:first-child {
      align-self: flex-start;
      text-align: left;
    }

    & > span:last-child {
      align-self: flex-end;
      text-align: right;
    }

    .sprout {
      animation: 1.8s grow infinite;

      @keyframes grow {
        0% {
          transform: scale(1);
        }
        50% {
          transform: scale(1.2);
        }
        100% {
          transform: scale(1);
        }
      }
    }
  }
}
</style>