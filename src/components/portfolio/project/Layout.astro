---
import Card from './Card.astro'

import { getCollection } from 'astro:content';
import { computeHardwareCO2ForProject, computeServiceCO2ForProject, round } from '../../../utils/co2';

const projects = await getCollection('projects');
const reports = await getCollection('reports');
const allHardware = await getCollection('hardware');
const allServices = await getCollection('services');

// For each report with a project_id, compute its total CO₂ (same formula as reports pages)
const reportDataByProjectId = Object.fromEntries(
  reports
    .filter(r => r.data.project_id)
    .map(r => {
      const { hardware_used, services_used, duration_days } = r.data;
      const hardwareItems = allHardware.filter(h => hardware_used.includes(h.id));
      const servicesItems = allServices.filter(s => services_used.includes(s.id));
      const totalKg = round(
        hardwareItems.reduce((sum, h) => sum + computeHardwareCO2ForProject(h.data, duration_days), 0) +
        servicesItems.reduce((sum, s) => sum + computeServiceCO2ForProject(s.data, duration_days), 0) / 1000,
        3
      );
      const co2PerView = r.data.use_metrics?.co2_per_view_g;
      return [r.data.project_id, { id: r.id, totalKg, co2PerView }];
    })
);

// Sort projects by date in descending order (newest first)
const sortedProjects = [...projects].sort((a, b) => {
  return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
});

// Group projects by year
const projectsByYear = sortedProjects.reduce((acc: Record<string, typeof projects>, project) => {
  const year = new Date(project.data.date).getFullYear().toString();
  if (!acc[year]) {
    acc[year] = [];
  }
  acc[year].push(project);
  return acc;
}, {} as Record<string, typeof projects>);

// Convert to array and sort years in descending order
const groupedProjectYears = Object.keys(projectsByYear)
  .map(year => ({ year: parseInt(year), projects: projectsByYear[year] }))
  .sort((a, b) => b.year - a.year);
---
<section>
  <h2>Recent Work</h2>
  
  {groupedProjectYears.map(group => (
    <div class="year-group">
      <h3 class="year-header">{group.year}</h3>
      <ul>
        {group.projects.map(proj => (
          <Card
            id={proj.id}
            project={proj.data}
            reportId={reportDataByProjectId[proj.id]?.id}
            reportCo2={reportDataByProjectId[proj.id]?.co2PerView}
          />
        ))}
      </ul>
    </div>
  ))}
</section>
<style lang="scss" scoped>
section {
  display: flex;
  flex-direction: column;

  h2 {
    align-self: flex-end;
    margin-bottom: 2rem;
  }

  .year-group {
    $bp: calc(360px + calc(78px + ($layoutMargin * 3)));
    margin-bottom: 3rem;
    display: flex;
    justify-content: space-between;
    position: relative;

    @include below($bp) {
      flex-direction: column;
    }
    
    .year-header {
      font-size: 2rem;
      line-height: 1.8rem;
      margin-bottom: 1.5rem;
      // padding-right: 1rem;
      width: max-content;
      // min-width: calc(78px + 1rem);
      height: fit-content;
      position: sticky;
      top: calc(var(--headerHeight) + 5px);
      z-index: 10;
      @include set-color();
      @include below($bp) {
        width: 100%;
        padding: calc(1rem + 5px) 0 1rem;
        top: calc(var(--headerHeight) + 0px);

      }
    }
  }

  ul {
    display: flex;
    flex-direction: column;
    gap: 3rem;
    margin-bottom: 2rem;
  }
}
</style>